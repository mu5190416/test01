rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'tea061101@gmail.com' || 
              exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())));
    }

    function isSuperAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'tea061101@gmail.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Validation helper for Order entity
    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 100 &&
             data.items is list && data.items.size() > 0 &&
             data.totalPrice is number && data.totalPrice > 0 &&
             data.orderDate is string && data.orderDate.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.createdAt == request.time;
    }

    // Validation helper for Admin entity
    function isValidAdmin(data) {
      return data.email is string && data.email.size() > 0 &&
             data.addedAt == request.time;
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      
      // Admin only operations
      allow list: if isAdmin();
      allow get: if isAdmin();
      allow delete: if isAdmin();
      
      allow update: if isAdmin() && isValidOrder(incoming());
    }

    match /admins/{adminEmail} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin() && isValidAdmin(incoming());
      allow delete: if isSuperAdmin();
    }
  }
}
